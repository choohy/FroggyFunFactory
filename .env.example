# Firebase web config — from Firebase Console > Project settings > General >
# Your apps > SDK setup and configuration. These values are safe to expose
# publicly (they end up in the built JS bundle); real security comes from
# firestore.rules, not from hiding this config. See README.md.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Set to "true" only for local/CI e2e test builds against the Firebase
# emulator (see test:e2e:build in package.json). Leave unset for normal
# dev/production builds.
VITE_USE_FIREBASE_EMULATOR=
